# InquiroAI — Environment Variables
# Copy this file to .env and fill in your values.

# ─── Required ──────────────────────────────────────────────────────────────────

# Neon serverless PostgreSQL connection string
DATABASE_URL=postgresql://user:password@hostname/dbname?sslmode=require

# Random 32-char secret for express-session
SESSION_SECRET=change-me-to-a-32-char-random-string

# Exactly 32 bytes — used for AES-256-GCM encryption of user API keys
ENCRYPTION_KEY=change-me-exactly-32-bytes-long!!

# ─── AI Provider (choose one approach) ─────────────────────────────────────────

# Option A: OpenRouter (recommended — single key routes all models)
OPENROUTER_API_KEY=sk-or-...
APP_URL=http://localhost:5000

# Option B: Direct provider keys (BYOK — stored encrypted in DB per user)
# These are no longer needed if using OpenRouter
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_API_KEY=...
# GROK_API_KEY=...

# ─── Memory (Layer 4 — optional) ───────────────────────────────────────────────
NOTION_API_KEY=secret_...
NOTION_MEMORY_DATABASE_ID=...

# ─── Knowledge Graph (Layer 5 — optional) ──────────────────────────────────────
# Server-level default vault path. Can also be set per-user in Settings → Preferences.
# OBSIDIAN_VAULT_PATH=/Users/you/Documents/InquiroAI

# ─── Pipeline model overrides (optional — defaults defined in server/config.ts) ─
# Override which model is used for internal pipeline calls (not user-facing chats)
# EVALUATOR_MODEL_ID=meta-llama/llama-3.1-8b-instruct
# COMPRESSION_MODEL_ID=anthropic/claude-haiku-4-5
# NOTION_CLASSIFIER_MODEL_ID=anthropic/claude-haiku-4-5

# ─── Cost estimation (optional) ────────────────────────────────────────────────
# Fallback per-token USD rates used when OpenRouter doesn't return pricing
# FALLBACK_PROMPT_COST_PER_TOKEN=0.000003
# FALLBACK_COMPLETION_COST_PER_TOKEN=0.000015

# ─── File limits (optional) ────────────────────────────────────────────────────
# MAX_FILE_SIZE_BYTES=10485760
# MAX_FILES_RETURNED=500
# MAX_FOLDER_DEPTH=3

# ─── Model catalog cache (optional) ────────────────────────────────────────────
# MODEL_CACHE_TTL_MS=86400000

# ─── Auth (Replit production only) ─────────────────────────────────────────────
# Not needed in development (mock auth is used automatically)
# REPLIT_DOMAINS=your-app.replit.app
# ISSUER_URL=https://replit.com/oidc
# REPL_ID=...

# ─── QA / Testing ──────────────────────────────────────────────────────────────
# Base URL for API tests — defaults to localhost:5000
# Set to your Replit URL to test against deployed app
# QA_BASE_URL=https://your-app.replit.app
ASANA_API_KEY=...
